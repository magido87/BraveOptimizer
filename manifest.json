{
  "manifest_version": 3,
  "name": "AI Chat DOM Optimizer",
  "version": "1.0.0",
  "description": "Reduce DOM bloat on supported AI chat sites by trimming older messages and restoring them on demand.",
  "author": "magido87",

  "permissions": ["storage"],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DOM Performance Optimizer"
  },

  "options_page": "options/options.html",

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://grok.x.ai/*",
        "https://x.com/i/grok*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "utils/config.js",
        "utils/storage.js",
        "utils/state-manager.js",
        "content/site-adapters/base-adapter.js",
        "content/site-adapters/chatgpt-adapter.js",
        "content/site-adapters/grok-adapter.js",
        "content/site-adapters/claude-adapter.js",
        "content/site-adapters/perplexity-adapter.js",
        "content/site-adapters/gemini-adapter.js",
        "content/site-detector.js",
        "content/dom-trimmer.js",
        "content/lazy-loader.js",
        "content/performance-boost.js",
        "overlay/overlay.js",
        "content/content.js"
      ],
      "css": ["styles/themes.css", "styles/glassmorphism.css", "overlay/overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
