{
  "manifest_version": 3,
  "name": "DOM Performance Optimizer",
  "version": "1.0.0",
  "description": "Universal browser performance optimizer - trim DOM, virtualize scrolling, boost performance on any heavy webpage",
  "author": "Performance Labs",
  
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://grok.x.ai/*",
    "https://x.com/i/grok*",
    "https://claude.ai/*",
    "https://www.perplexity.ai/*",
    "https://gemini.google.com/*",
    "https://bard.google.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.reddit.com/*",
    "https://www.facebook.com/*",
    "https://*/*"
  ],
  
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DOM Performance Optimizer"
  },
  
  "options_page": "options/options.html",
  
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://grok.x.ai/*",
        "https://x.com/i/grok*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*",
        "https://gemini.google.com/*",
        "https://bard.google.com/*"
      ],
      "js": [
        "utils/config.js",
        "utils/storage.js",
        "utils/state-manager.js",
        "content/site-adapters/base-adapter.js",
        "content/site-adapters/chatgpt-adapter.js",
        "content/site-adapters/grok-adapter.js",
        "content/site-adapters/claude-adapter.js",
        "content/site-adapters/perplexity-adapter.js",
        "content/site-adapters/gemini-adapter.js",
        "content/site-detector.js",
        "content/dom-trimmer.js",
        "content/lazy-loader.js",
        "content/performance-boost.js",
        "overlay/overlay.js",
        "content/content.js"
      ],
      "css": [
        "styles/themes.css",
        "styles/glassmorphism.css",
        "overlay/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": [
        "styles/*.css",
        "icons/*.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

